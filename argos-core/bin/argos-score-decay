#!/usr/bin/env python3
"""
ARGOS Score Decay - Night Job
Runs weekly, pulls all scores toward 500 (mean regression)
Formula: score = score * 0.95 + 500 * 0.05
No external API calls - local DB only [E602 on fail]
"""
import asyncio, asyncpg, os, logging
from datetime import datetime

logging.basicConfig(level=logging.INFO, format='%(asctime)s [score-decay] %(message)s')
log = logging.getLogger(__name__)

async def main():
    env = {}
    with open('/root/.argos.env') as f:
        for line in f:
            line = line.strip()
            if '=' in line and not line.startswith('#'):
                k, v = line.split('=', 1)
                env[k.strip()] = v.strip()

    try:
        conn = await asyncpg.connect(
            host='11.11.11.111',
            port=5433,
            user=env.get('DB_USER', 'claude'),
            password=env.get('DB_PASSWORD'),
            database=env.get('DB_NAME', 'claudedb')
        )
    except Exception as e:
        log.error(f"[E101] DB connection fail: {e}")
        return 1

    try:
        # Score decay: pull toward 500
        result = await conn.execute("""
            UPDATE command_scores
            SET score = GREATEST(
                CASE WHEN pinned THEN 400 ELSE 0 END,
                ROUND(score * 0.95 + 500 * 0.05)::integer
            )
            WHERE score != 500
            AND pinned = FALSE
        """)
        updated = int(result.split()[-1])
        log.info(f"Score decay applied: {updated} commands updated")

        # Mark unstable calups
        result2 = await conn.execute("""
            UPDATE calup_scores
            SET status = 'unstable'
            WHERE fail_streak >= unstable_threshold
              AND status = 'active'
        """)
        unstable = int(result2.split()[-1])
        log.info(f"Calups marked unstable: {unstable}")

        # Log in notes
        await conn.execute("""
            INSERT INTO notes (category, content, priority, status)
            VALUES ('general', $1, 3, 'active')
        """, f"Score decay ran at {datetime.now().strftime('%Y-%m-%d %H:%M')} - {updated} commands, {unstable} unstable calups")

        log.info("Score decay complete")
        return 0

    except Exception as e:
        log.error(f"[E602] Score update fail: {e}")
        return 1
    finally:
        await conn.close()

if __name__ == "__main__":
    exit(asyncio.run(main()))
