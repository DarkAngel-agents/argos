# ARGOS Environment Configuration
# Copy to .argos.env and fill in your values.
# All values without a default in code MUST be set or ARGOS will fail to start.

# ─── API authentication (strongly recommended) ───────────────────────────────
# Shared secret required in the X-API-Key header for every protected endpoint.
# Generate one with: openssl rand -hex 32
# If LEFT UNSET, the API starts in DEV MODE and accepts every request without
# auth — fine for local development on a private network, NEVER for any host
# reachable from the public internet.
# ARGOS_API_KEY=

# CORS allow_origins as a comma-separated list of origins. Sets which web
# origins are allowed to talk to the API from a browser. Wildcard "*" is
# refused — if you supply it, the API falls back to the localhost default.
# Default: http://localhost:666,http://127.0.0.1:666
# Example: ARGOS_CORS_ORIGINS=https://argos.example.com,https://admin.example.com
# ARGOS_CORS_ORIGINS=

# ─── LLM provider (required) ──────────────────────────────────────────────────
# Anthropic API key — primary LLM. Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Legacy alias for ANTHROPIC_API_KEY. Some code paths in api/chat.py read either.
# Setting only ANTHROPIC_API_KEY is enough; this is here for backward compat.
# CLAUDE_TOKEN=sk-ant-your-key-here

# Override the default Claude model used by the agent loop and chat.
# Default in code: claude-sonnet-4-6
# Other valid values: claude-opus-4-7, claude-haiku-4-5
# ARGOS_AGENT_MODEL=claude-sonnet-4-6

# ─── Database (required) ──────────────────────────────────────────────────────
DB_HOST=argos-db
DB_PORT=5432
DB_USER=claude
DB_PASSWORD=change-me-to-strong-password
DB_NAME=claudedb

# ─── Service URLs (optional overrides) ────────────────────────────────────────
# Public URL where the ARGOS API is reachable. Used by the nanite bootstrap
# config (api/nanite.py) and embedded in generated NixOS ISOs.
# Set this to the URL nanite VMs will use to call back home.
# Default in code: http://11.11.11.111:666 (the maintainer's lab — change it).
# ARGOS_URL=http://your-host:666

# ─── Optional providers ───────────────────────────────────────────────────────
# Grok (xAI) API key — used by the "auto-learn skill" web search in api/chat.py
# and by skill_selector.py for ranking. Optional; ARGOS works without it.
# Get one at: https://console.x.ai
# GROK_API_KEY=xai-your-key-here

# Ollama local LLM endpoint — used as fallback for compression and analysis.
# OLLAMA_HOST=http://localhost:11434

# ─── Integrations (optional) ──────────────────────────────────────────────────
# Home Assistant long-lived access token. Used by the HA skill (not yet wired
# end-to-end). Skip if you do not run HA.
# HA_URL=https://your-ha:8123
# HA_TOKEN=

# GitHub personal access token. Required only if using argos-export-github-public.sh
# to mirror parts of the project to a public fork.
# GITHUB_TOKEN=
