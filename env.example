# ============================================================================
# ARGOS Environment Configuration
# ----------------------------------------------------------------------------
# Copy this file to /root/.argos.env (or wherever your stack reads from) and
# fill in real values. Variables without a code default MUST be set or ARGOS
# will refuse to start. Variables with a code default can be left commented.
#
# DO NOT commit your filled .argos.env to git. The default `.gitignore`
# already excludes `.env`, `.env.*`, `*.token`, `config/argos-private.yaml`,
# `.vault-cc-api`, and `.vikunja-token`.
# ============================================================================


# ============================================================
# ARGOS_API_KEY
# Shared secret required in the X-API-Key header for protected endpoints.
# Required: no (but STRONGLY recommended for any non-localhost deployment)
# Format: arbitrary string >= 32 chars (high-entropy)
# Default: unset = DEV MODE (every request accepted without auth — ONLY for
#          local development on a private network, NEVER for a host reachable
#          from the public internet).
# Where to get: generate locally with `openssl rand -hex 32`
# Example: ARGOS_API_KEY=PLACEHOLDER_64_HEX_CHARS
# ============================================================
# ARGOS_API_KEY=


# ============================================================
# ARGOS_CORS_ORIGINS
# Comma-separated list of web origins allowed to call the API from a browser.
# Required: no
# Format: comma-separated list of full origins (scheme + host [+ port])
# Default: http://localhost:666,http://127.0.0.1:666
# Note: wildcard "*" is refused; supplying it falls back to the default.
# Example: ARGOS_CORS_ORIGINS=https://argos.example.com,https://admin.example.com
# ============================================================
# ARGOS_CORS_ORIGINS=


# ============================================================
# ANTHROPIC_API_KEY
# Required for ARGOS to communicate with Claude (Anthropic LLM). Used by
# the agent loop, chat, and most skill-selection paths.
# Required: yes (for agent loop functionality)
# Format: sk-ant-api03-... (long base64-like string)
# Where to get: https://console.anthropic.com/settings/keys
# If unset: ARGOS still starts but agent calls fail with 401 from upstream.
# Example: ANTHROPIC_API_KEY=sk-ant-api03-PLACEHOLDER
# ============================================================
ANTHROPIC_API_KEY=sk-ant-api03-PLACEHOLDER


# ============================================================
# CLAUDE_TOKEN
# Legacy alias for ANTHROPIC_API_KEY. Some older code paths in api/chat.py
# accept either name; setting ANTHROPIC_API_KEY alone is sufficient.
# Required: no (only for backward compatibility)
# Format: same as ANTHROPIC_API_KEY
# ============================================================
# CLAUDE_TOKEN=sk-ant-api03-PLACEHOLDER


# ============================================================
# ARGOS_AGENT_MODEL
# Override the default Claude model used by the agent loop and chat.
# Required: no
# Default: claude-sonnet-4-6
# Other valid values: claude-opus-4-7, claude-haiku-4-5
# Example: ARGOS_AGENT_MODEL=claude-opus-4-7
# ============================================================
# ARGOS_AGENT_MODEL=claude-sonnet-4-6


# ============================================================
# DB_HOST / DB_PORT / DB_USER / DB_PASSWORD / DB_NAME
# PostgreSQL connection parameters for the ARGOS database.
# Required: yes (all five)
# Format:
#   DB_HOST=hostname or IP (default: argos-db, the docker service name)
#   DB_PORT=integer (default: 5432; use 5433 if going through HAProxy)
#   DB_USER=role name (default: claude)
#   DB_PASSWORD=string (NO default — set a strong one and store securely)
#   DB_NAME=database name (default: claudedb)
# Where to get: you set them when bringing up postgres. Use `openssl rand
#               -base64 32 | tr -d '/+=' | head -c 32` for the password.
# Example values below are placeholders — change before running.
# ============================================================
DB_HOST=argos-db
DB_PORT=5432
DB_USER=claude
DB_PASSWORD=change-me-to-a-strong-random-password
DB_NAME=claudedb


# ============================================================
# ARGOS_URL
# Public URL where the ARGOS API is reachable. Embedded in nanite ISOs and
# used for callbacks (api/nanite.py).
# Required: no
# Format: http(s)://host[:port]  (no trailing slash)
# Default in code: http://localhost:666
# Note: change this away from the default before any nanite deploy.
# Example: ARGOS_URL=https://argos.your-domain.tld
# ============================================================
# ARGOS_URL=http://localhost:666


# ============================================================
# HERMES_URL
# URL of the secondary ARGOS replica used as HTTP fallback by the heartbeat
# daemon (heartbeat.py:147) when the primary DB is unreachable.
# Required: no
# Format: http(s)://host[:port]
# Default in code: http://localhost:666
# Note: on a single-node deployment you can leave this unset.
# Example: HERMES_URL=http://argos-secondary.lan:666
# ============================================================
# HERMES_URL=http://localhost:666


# ============================================================
# UI_LANG
# Choose interface language for the ARGOS web UI.
# Required: no
# Options: en (default), fr (planned v0.2.1), ro (planned v0.2.1)
# Default: en
# Note: v0.2.0 ships with English only. FR/RO localization arrives in v0.2.1.
# Example: UI_LANG=en
# ============================================================
# UI_LANG=en


# ============================================================
# GROK_API_KEY (a.k.a. XAI_API_KEY)
# xAI Grok API key. Used by the auto-learn skill web search in api/chat.py
# and by skill_selector.py for ranking. Optional; ARGOS works without it.
# Required: no
# Format: xai-... (string)
# Where to get: https://console.x.ai
# If unset: web search / ranking falls back to Anthropic only.
# Example: GROK_API_KEY=xai-PLACEHOLDER
# ============================================================
# GROK_API_KEY=xai-PLACEHOLDER


# ============================================================
# OLLAMA_HOST
# Local Ollama endpoint, used as a fallback for compression and analysis
# tasks when the cloud LLM is unreachable or rate-limited.
# Required: no
# Format: http://host[:port] (no trailing slash)
# Default: http://localhost:11434
# Where to get: install Ollama from https://ollama.com and run `ollama serve`.
# Example: OLLAMA_HOST=http://11.11.11.111:11435
# ============================================================
# OLLAMA_HOST=http://localhost:11434


# ============================================================
# HA_URL / HA_TOKEN
# Home Assistant integration. Used by the (not yet wired end-to-end) HA skill.
# Required: no
# Format:
#   HA_URL=https://your-ha[:port] (no trailing slash)
#   HA_TOKEN=long-lived access token (HA UI -> Profile -> Long-Lived Access Tokens)
# Skip if you do not run HA.
# ============================================================
# HA_URL=https://your-ha:8123
# HA_TOKEN=


# ============================================================
# GITHUB_TOKEN
# GitHub personal access token. Required only if using
# argos-export-github-public.sh to mirror parts of the project to a public fork.
# Required: no (unless you actively use the export script)
# Format: github_pat_... (fine-grained) or ghp_... (classic)
# Where to get: https://github.com/settings/tokens
# Recommended scope: public_repo (for export to a public mirror)
# ============================================================
# GITHUB_TOKEN=


# ============================================================
# RATELIMIT_STORAGE_URI
# Override the slowapi rate-limit storage backend. Default ARGOS uses the
# in-code Redis backend at redis://argos-redis:6379 (set in api/rate_limit.py).
# Required: no (handled in code; only set if running outside the docker swarm)
# Format: redis://host:port  OR  memory://  (last resort, NOT cross-replica)
# Note: with `memory://` the rate limiter does not aggregate across replicas.
# Example: RATELIMIT_STORAGE_URI=redis://my-redis.lan:6379
# ============================================================
# RATELIMIT_STORAGE_URI=redis://argos-redis:6379
